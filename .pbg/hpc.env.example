# HPC SSH + SLURM configuration — workspace-scoped.
# Copy to hpc.env and fill in your values.
# NEVER commit hpc.env — it contains paths to private SSH keys.
#
# Generate the known_hosts file once:
#   ssh-keyscan <your-login-node> > .pbg/hpc_known_hosts
#
# Then populate this file and copy it:
#   cp .pbg/hpc.env.example .pbg/hpc.env

SLURM_SUBMIT_HOST=
SLURM_SUBMIT_USER=
SLURM_SUBMIT_KEY_PATH=
SLURM_SUBMIT_KNOWN_HOSTS=

SLURM_PARTITION=
SLURM_QOS=

HPC_IMAGE_BASE_PATH=
HPC_SIM_BASE_PATH=
HPC_LOG_BASE_PATH=
HPC_REPO_BASE_PATH=

# singularity_cmd: use "apptainer" (default) or "singularity"
SINGULARITY_CMD=apptainer